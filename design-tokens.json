        "success":       { "$value": "{color.primitive.green.400}", "$type": "color", "$description": "success-bg上のテキスト用。旧値#4CAF6Bは4.18:1でAA未達。検証: 6.59:1。" },
        "success-bg":    { "$value": "rgba(30,142,62,0.16)", "$type": "color" },
